{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Legend Standards",
  "description": "Plain-English explanations, classroom examples, and citations for U.S. K-12 learning standards.",
  "colors": {
    "primary": "#12936B",
    "light": "#2AAF82",
    "dark": "#0E7553"
  },
  "favicon": "/favicon.ico",
  "icons": {
    "library": "lucide"
  },
  "fonts": {
    "heading": {
      "family": "Fraunces",
      "weight": 500,
      "format": "woff2"
    },
    "body": {
      "family": "Inter",
      "weight": 400,
      "format": "woff2"
    }
  },
  "appearance": {
    "default": "light",
    "strict": false
  },
  "seo": {
    "indexing": "all",
    "metatags": {
      "og:site_name": "Legend Standards",
      "og:locale": "en_US",
      "og:type": "website",
      "og:image": "/og/default.png",
      "twitter:card": "summary_large_image",
      "twitter:site": "@legendeducation",
      "robots": "index,follow,max-snippet:-1,max-image-preview:large,max-video-preview:-1"
    }
  },
  "metadata": {
    "timestamp": true
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "perplexity", "mcp", "cursor", "vscode"]
